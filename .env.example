DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

# Leave DATABASE_URL blank for local SQLite.
# PostgreSQL example:
# DATABASE_URL=postgres://exam_vle:password@localhost:5432/exam_vle
DATABASE_URL=
DATABASE_SSL_REQUIRE=False

# Future generated-question provider hook.
QUESTION_GENERATOR_PROVIDER=local
QUESTION_GENERATOR_API_KEY=
